# Copy to .env.local for local development (Next.js loads .env.local automatically)

# Required for AI features (primary)
GEMINI_API_KEY=
# Optional fallback if the primary key hits quota or errors (same format as above)
GEMINI_API_KEY_1=

# Optional — Neon PostgreSQL (pooler connection string from Neon dashboard)
# Without this, /api/stats returns placeholder numbers and contract tracking is skipped.
DATABASE_URL=

# Optional — Google Search Console HTML tag verification token (meta tag content value only).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
