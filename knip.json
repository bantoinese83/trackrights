{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/app/**/*.{ts,tsx}",
    "src/app/**/route.{ts,tsx}",
    "src/app/**/page.{ts,tsx}",
    "src/app/**/layout.{ts,tsx}",
    "next.config.mjs",
    "tailwind.config.ts",
    "postcss.config.mjs"
  ],
  "project": [
    "src/**/*.{ts,tsx,js,jsx}",
    "*.{ts,tsx,js,jsx,mjs}",
    "next.config.*",
    "tailwind.config.*",
    "postcss.config.*"
  ],
  "ignore": [
    "**/*.d.ts",
    "**/node_modules/**",
    ".next/**",
    "out/**",
    "build/**",
    "dist/**",
    "public/**",
    "next-env.d.ts",
    "declarations.d.ts",
    "index.d.ts",
    "react-pdf.d.ts",
    "pdfjs-dist.d.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "src/components/ui/**",
    "src/hooks/index.ts",
    "src/hooks/use-mobile.tsx",
    "src/hooks/useDebounce.ts",
    "src/hooks/useMediaQuery.ts",
    "src/lib/types/index.ts",
    "src/lib/utils/utils.ts",
    "src/services/cache.service.ts",
    "src/services/index.ts",
    "src/utils/pdfGenerator.ts"
  ],
  "ignoreDependencies": [
    "@types/*",
    "@radix-ui/react-alert-dialog",
    "@radix-ui/react-aspect-ratio",
    "@radix-ui/react-avatar",
    "@radix-ui/react-collapsible",
    "@radix-ui/react-context-menu",
    "@radix-ui/react-dialog",
    "@radix-ui/react-dropdown-menu",
    "@radix-ui/react-hover-card",
    "@radix-ui/react-menubar",
    "@radix-ui/react-navigation-menu",
    "@radix-ui/react-progress",
    "@radix-ui/react-radio-group",
    "@radix-ui/react-scroll-area",
    "@radix-ui/react-separator",
    "@radix-ui/react-switch",
    "@radix-ui/react-tabs",
    "@radix-ui/react-toggle",
    "@radix-ui/react-toggle-group",
    "cmdk",
    "embla-carousel-react",
    "input-otp",
    "jspdf",
    "next-themes",
    "react-day-picker",
    "react-hook-form",
    "react-resizable-panels",
    "react-tweet",
    "recharts",
    "rough-notation",
    "sonner",
    "styled-jsx",
    "vaul"
  ],
  "ignoreIssues": {
    "src/lib/errors.ts": ["exports"],
    "src/lib/utils/contract-optimizer.ts": ["exports"],
    "src/lib/utils/index.ts": ["exports"],
    "src/lib/validation.ts": ["exports"],
    "src/hooks/useContractForm.ts": ["types"],
    "src/lib/types/api.ts": ["types"]
  },
  "ignoreBinaries": ["lsof"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": [
        "src/app/**/*.{ts,tsx}",
        "src/app/**/route.{ts,tsx}",
        "src/app/**/page.{ts,tsx}",
        "src/app/**/layout.{ts,tsx}",
        "next.config.mjs"
      ],
      "project": ["src/**/*.{ts,tsx}", "*.{ts,tsx,js,jsx,mjs}"]
    }
  },
  "next": {
    "entry": [
      "src/app/**/*.{ts,tsx}",
      "src/app/**/route.{ts,tsx}",
      "src/app/**/page.{ts,tsx}",
      "src/app/**/layout.{ts,tsx}"
    ]
  }
}
